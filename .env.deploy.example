# ── Deployment env for docker compose (copy to .env on the VPS) ──
# App
JWT_SECRET="change-me-to-a-random-string-at-least-32-chars"
NEXT_PUBLIC_APP_URL="https://your-domain.com"
APP_PORT=3000

# Set to "true" once to insert the demo user (demo@tarot.app / 123456)
SEED_DB=false

# MySQL (used by the bundled db service and the app's DATABASE_URL)
MYSQL_DATABASE=tarot
MYSQL_USER=tarot
MYSQL_PASSWORD="change-me-db-password"
MYSQL_ROOT_PASSWORD="change-me-root-password"
